# RunPod Serverless - Ollama (Gemma 3 27B + EmbeddingGemma)
#
# Build from repo root:
#   docker build -f runpod/Dockerfile.ollama -t your-registry/3drag-ollama:latest .
#
# Push:
#   docker push your-registry/3drag-ollama:latest
#
# Requires GPU with 16GB+ VRAM (RTX 4080, L4, A10G, etc.)
# Image size: ~8GB (models baked in for fast cold starts)

FROM nvidia/cuda:12.4.0-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV OLLAMA_HOST=0.0.0.0

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install Ollama
RUN curl -fsSL https://ollama.com/install.sh | sh

# Install Python dependencies
RUN pip3 install --no-cache-dir \
    runpod \
    requests \
    pillow

# Copy handler
COPY runpod/handler_ollama.py /app/handler.py

# Pre-pull models during build (baked into image for faster cold starts)
# MiniCPM-V 2.6: ~5GB, EmbeddingGemma: ~300MB
RUN ollama serve & \
    sleep 10 && \
    ollama pull minicpm-v && \
    ollama pull embeddinggemma && \
    pkill ollama || true

# Start script: launch Ollama server, wait for ready, then run handler
RUN echo '#!/bin/bash\n\
set -e\n\
echo "Starting Ollama server..."\n\
ollama serve &\n\
\n\
# Wait for Ollama to be ready\n\
for i in {1..30}; do\n\
    if curl -s http://localhost:11434/api/tags > /dev/null 2>&1; then\n\
        echo "Ollama is ready!"\n\
        break\n\
    fi\n\
    echo "Waiting for Ollama... ($i/30)"\n\
    sleep 1\n\
done\n\
\n\
echo "Starting RunPod handler..."\n\
python3 -u handler.py\n\
' > /app/start.sh && chmod +x /app/start.sh

CMD ["/app/start.sh"]
